generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Workspace ────────────────────────────────────────────────────────────────

model Workspace {
  id   String @id  // = URL slug, e.g. "nimbus"
  name String

  members    WorkspaceMember[]
  projects   Project[]
  labels     Label[]
  teams      Team[]
  statuses   Status[]
  priorities Priority[]
  issueTypes IssueType[]
  roles      Role[]
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id     String @id
  name   String
  handle String @unique
  email  String @unique
  color  String

  workspaces      WorkspaceMember[]
  assignedIssues  Issue[]      @relation("IssueAssignee")
  reportedIssues  Issue[]      @relation("IssueReporter")
  comments        Comment[]
  leadingTeams    Team[]       @relation("TeamLead")
  teamMemberships TeamMember[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String  @default("member")
  pending     Boolean @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId],      references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id          String @id
  workspaceId String
  name        String
  prefix      String
  color       String

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues    Issue[]
  teams     TeamProject[]

  @@unique([workspaceId, prefix])
}

// ─── Workspace config (customizable per workspace) ───────────────────────────

model Status {
  id          String  @id
  workspaceId String
  name        String
  short       String
  color       String
  isColumn    Boolean @default(true)
  position    Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, position])
}

model Priority {
  id          Int    @id
  workspaceId String
  key         String
  name        String
  color       String
  position    Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId, position])
}

model IssueType {
  id          String @id
  workspaceId String
  name        String
  color       String
  position    Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, position])
}

model Role {
  id          String @id
  workspaceId String
  name        String
  desc        String @default("")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, id])
}

// ─── Labels ──────────────────────────────────────────────────────────────────

model Label {
  id          String @id
  workspaceId String
  name        String
  color       String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─── Issues ──────────────────────────────────────────────────────────────────

model Issue {
  id          String   @id
  key         Int
  title       String
  status      String   @default("backlog")
  priority    Int      @default(0)
  description String   @default("")
  type        String   @default("feature")
  labels      String[]
  rank        Float    @default(0)
  created     DateTime @default(now())
  updated     DateTime @updatedAt

  assigneeId String?
  reporterId String
  projectId  String

  assignee User?    @relation("IssueAssignee", fields: [assigneeId], references: [id])
  reporter User     @relation("IssueReporter", fields: [reporterId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])
  comments Comment[]

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([assigneeId])
}

// ─── Comments ────────────────────────────────────────────────────────────────

model Comment {
  id      String   @id
  body    String
  created DateTime @default(now())

  issueId  String
  authorId String

  issue  Issue @relation(fields: [issueId],  references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])
}

// ─── Teams ───────────────────────────────────────────────────────────────────

model Team {
  id          String @id
  workspaceId String
  name        String
  key         String
  color       String
  desc        String @default("")

  leadId String
  lead   User   @relation("TeamLead", fields: [leadId], references: [id])

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  projects  TeamProject[]

  @@unique([workspaceId, key])
}

model TeamMember {
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model TeamProject {
  teamId    String
  projectId String

  team    Team    @relation(fields: [teamId],    references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([teamId, projectId])
}
