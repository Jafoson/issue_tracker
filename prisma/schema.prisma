generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Workspace ────────────────────────────────────────────────────────────────

model Workspace {
  id    String @id
  name  String
  slug  String @unique
  color String @default("#6e63e6")

  members    WorkspaceMember[]
  projects   Project[]
  labels     Label[]
  teams      Team[]
  statuses   WorkspaceStatus[]
  priorities WorkspacePriority[]
  issueTypes WorkspaceIssueType[]
  roles      Role[]
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String  @id
  name         String
  handle       String  @unique
  email        String  @unique
  color        String
  passwordHash String?

  workspaces         WorkspaceMember[]
  assignedIssues     Issue[]         @relation("IssueAssignee")
  reportedIssues     Issue[]         @relation("IssueReporter")
  comments           Comment[]
  leadingTeams       Team[]          @relation("TeamLead")
  teamMemberships    TeamMember[]
  projectMemberships ProjectMember[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String  @default("member")
  pending     Boolean @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId],      references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id           String @id
  workspaceId  String
  name         String
  slug         String
  prefix       String
  color        String
  lastIssueKey Int    @default(0)
  visibility   String @default("public") // "public" | "private"

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues    Issue[]
  teams     TeamProject[]
  labels    Label[]
  members   ProjectMember[]

  @@unique([workspaceId, prefix])
  @@unique([workspaceId, slug])
}

// ─── Project membership (projekt-spezifische Rollen & Guests) ─────────────────

model ProjectMember {
  projectId String
  userId    String
  role      String // = Role.key dieses Workspace; überschreibt die Workspace-Rolle für dieses Projekt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}

// ─── Global config (shared across workspaces via join tables) ─────────────────

model Status {
  id       String  @id
  name     String
  short    String
  color    String
  isColumn Boolean @default(true)
  position Int

  workspaces WorkspaceStatus[]
}

model WorkspaceStatus {
  workspaceId String
  statusId    String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  status    Status    @relation(fields: [statusId],    references: [id], onDelete: Cascade)

  @@id([workspaceId, statusId])
}

model Priority {
  id       Int    @id
  key      String @unique
  name     String
  color    String
  position Int

  workspaces WorkspacePriority[]
}

model WorkspacePriority {
  workspaceId String
  priorityId  Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  priority  Priority  @relation(fields: [priorityId],  references: [id], onDelete: Cascade)

  @@id([workspaceId, priorityId])
}

model IssueType {
  id       String @id
  name     String
  color    String
  position Int

  workspaces WorkspaceIssueType[]
}

model WorkspaceIssueType {
  workspaceId String
  issueTypeId String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issueType IssueType @relation(fields: [issueTypeId], references: [id], onDelete: Cascade)

  @@id([workspaceId, issueTypeId])
}

// ─── Rollen & Permissions (RBAC) ──────────────────────────────────────────────

// Rollen sind workspace-spezifisch: jeder Workspace hat seine eigenen Role-Zeilen
// (die 7 Default-Rollen werden geseedet, Admins können via workspace.role.manage
// eigene anlegen). `key` ist die stabile, code-referenzierbare ID und entspricht
// WorkspaceMember.role / ProjectMember.role innerhalb desselben Workspace.
model Role {
  id          String  @id
  workspaceId String
  key         String
  name        String
  desc        String  @default("")
  rank        Int     @default(0)
  editable    Boolean @default(true)

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  permissions RolePermission[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

// Permission-Keys sind global und hardcoded im Code (lib/rbac.ts). Die Tabelle
// dient als FK-Ziel und dokumentiert die verfügbaren Permissions.
model Permission {
  key  String @id
  desc String @default("")

  roles RolePermission[]
}

model RolePermission {
  roleId        String
  permissionKey String

  role       Role       @relation(fields: [roleId],        references: [id],  onDelete: Cascade)
  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([roleId, permissionKey])
  @@index([permissionKey])
}

// ─── Labels (workspace-specific) ─────────────────────────────────────────────

model Label {
  id          String  @id
  workspaceId String
  projectId   String?
  name        String
  slug        String
  color       String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId],   references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([projectId])
}

// ─── Issues ──────────────────────────────────────────────────────────────────

model Issue {
  id          String   @id
  key         Int
  title       String
  status      String   @default("backlog")
  priority    Int      @default(0)
  description String   @default("")
  type        String   @default("feature")
  labels      String[]
  rank        Float    @default(0)
  created     DateTime @default(now())
  updated     DateTime @updatedAt

  assigneeId String?
  reporterId String
  projectId  String

  assignee User?    @relation("IssueAssignee", fields: [assigneeId], references: [id])
  reporter User     @relation("IssueReporter", fields: [reporterId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])
  comments Comment[]

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([assigneeId])
}

// ─── Comments ────────────────────────────────────────────────────────────────

model Comment {
  id      String   @id
  body    String
  created DateTime @default(now())

  issueId  String
  authorId String

  issue  Issue @relation(fields: [issueId],  references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])
}

// ─── Teams ───────────────────────────────────────────────────────────────────

model Team {
  id          String @id
  workspaceId String
  name        String
  key         String
  color       String
  desc        String @default("")

  leadId String
  lead   User   @relation("TeamLead", fields: [leadId], references: [id])

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  projects  TeamProject[]

  @@unique([workspaceId, key])
}

model TeamMember {
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model TeamProject {
  teamId    String
  projectId String

  team    Team    @relation(fields: [teamId],    references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([teamId, projectId])
}
