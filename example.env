# Local development — matches docker-compose.yml (orbit-postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/IssueTracker"

# Auth.js — Pflicht. Zufälligen Wert generieren mit: bunx auth secret
AUTH_SECRET="dev-secret-minimum-32-characters-long!"

# Optionale OAuth-Provider. Nur gesetzt aktiv (sonst nur E-Mail/Passwort-Login).
# GitHub:  https://github.com/settings/developers
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# Google:  https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
